model User {
    id           String       @id @default(uuid())
    name         String       @db.VarChar()
    email        String       @unique
    password     String
    activeStatus ActiveStatus @default(ACTIVE)
    role         Role         @default(USER)
    profile      Profile?
    posts         Post[]
    comments      Comment[]
    createdAt    DateTime     @default(now())
    updatedAt    DateTime     @updatedAt

    @@map("users")
}
